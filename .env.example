# Optional LLM provider. If unset, the agent still returns deterministic analysis.
# For GreenNode AIP, use an OpenAI-compatible endpoint from AgentBase/AI Platform.
LLM_API_KEY=
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_MODEL=qwen/qwen3-5-27b
LLM_TIMEOUT_SECONDS=90

# Default is FastAPI/CORS runtime so GitHub Pages can call AgentBase directly.
# Only set true if you specifically need the GreenNode SDK app wrapper.
USE_GREENNODE_AGENTBASE_APP=false

# Do not put Tableau PAT secrets in Git.
# Local Tableau MCP config is stored outside the repo at ~/.codex/tableau-mcp.env.
TABLEAU_AUTO_REFRESH=false
TABLEAU_HTTP_TIMEOUT_SECONDS=30
SERVER=https://atlas.vng.com.vn
SITE_NAME=ZLPDataServices
PAT_NAME=
PAT_VALUE=
REST_API_VERSION=3.4
TABLEAU_VIEW_INSURANCE_PERFORMANCE_ID=d3bc93f4-3036-449c-84f8-0a4875cbfc5b
TABLEAU_VIEW_INSURANCE_TRAFFIC_ID=d580ce59-6cc4-4e74-93e0-79b75b2f9154
TABLEAU_VIEW_PROMOTION_SUMMARY_ID=5f8e8ee3-2a76-417b-91ab-e2f4e680e286
# Optional: a Tableau view that exports product/AppID/SKU rows. Without this, AppID-level answers require uploaded/product CSV.
TABLEAU_VIEW_PRODUCT_PERFORMANCE_ID=
TABLEAU_APPID_FILTER_FIELDS=Sku,App ID
TABLEAU_PERFORMANCE_APPID_FILTER_FIELDS=Sku,App ID
TABLEAU_PRODUCT_APPID_FILTER_FIELDS=App ID,Sku,SKU Name
TABLEAU_TRAFFIC_APPID_FILTER_FIELDS=SKU NAME,APP NAME,App ID
TABLEAU_PROMOTION_APPID_FILTER_FIELDS=*App ID,App ID,Campaign Code,Campaign ID

# Daily email report. Fill these locally only; do not commit .env.
AGENT_ENDPOINT=https://endpoint-14358055-e169-46fc-9328-8e14537c46cd.agentbase-runtime.aiplatform.vngcloud.vn
DAILY_REPORT_RECIPIENTS=hanlgb@vng.com.vn,mynt5@vng.com.vn,tramntq@vng.com.vn,tranvhd@vng.com.vn
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
